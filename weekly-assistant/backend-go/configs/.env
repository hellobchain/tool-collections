# 数据库
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=yourpassword
DB_NAME=weekly_assistant
DB_LOG_LEVEL=1

# JWT
JWT_SECRET=your-secret-key-change-in-production

# DeepSeek (百度云)
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_BASE_URL=https://your-baidu-cloud-deepseek-url/v1
DEEPSEEK_MODEL=deepseek-v4-flash

# 服务
PORT=8000

# 初始化用户
INIT_USER_EMAIL=Admin@163.com
INIT_USER_PASSWORD=Admin@123456
INIT_USER_USERNAME=admin

# JSONL 文件读取白名单目录（为空则不限制）
JSONL_ALLOWED_DIR=
